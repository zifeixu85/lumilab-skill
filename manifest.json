  "compatibility": {
    "claude-code": ">=1.0.0",
    "openclaw": ">=2026.4.25",
    "hermes": ">=0.13.0",
    "cursor": ">=0.45.0",
    "codex": ">=0.10.0",
    "gemini-cli": ">=0.5.0"
  },
  "prerequisites": {
    "runtime": [
      {
        "name": "bun",
        "version": ">=1.0",
        "required": true
      },
      {
        "name": "node",
        "version": ">=20",
        "required": false,
        "note": "fallback only"
      },
      {
        "name": "wrangler",
        "required": false,
        "note": "for `lumilab deploy`"
      }
    ],
    "env_vars": [],
    "tool_tokens": [
      {
        "name": "CLOUDFLARE_API_TOKEN",
        "required": false,
        "scope": "deploy"
      },
      {
        "name": "TAVILY_API_KEY",
        "required": false,
        "scope": "research-platforms"
      },
      {
        "name": "TIKHUB_API_KEY",
        "required": false,
        "scope": "research-platforms"
      },
      {
        "name": "DATAFORSEO_LOGIN",
        "required": false,
        "scope": "research-keywords"
      },
      {
        "name": "DATAFORSEO_PASSWORD",
        "required": false,
        "scope": "research-keywords"
      },
      {
        "name": "KEYWORDSEVERYWHERE_API_KEY",
        "required": false,
        "scope": "research-keywords"
      }
    ]
  },
  "install": {
    "claude-code": "bash <(curl -fsSL https://raw.githubusercontent.com/zifeixu85/lumilab/main/install.sh)",
    "openclaw": "openclaw skills install lumilab",
    "hermes": "/skills install https://github.com/zifeixu85/lumilab"
  },
  "entrypoints": {
    "cli": "./scripts/lumilab",
    "install": "./install.sh"
  },
  "release": {
    "channel": "stable",
    "version": "1.6.2",
    "date": "2026-05-22"
  },
  "bootstrap": {
    "description": "Skill scripts need bun >=1.0. Host agent should run this once before first script invocation.",
    "check": "command -v bun",
    "install": "curl -fsSL https://bun.sh/install | bash",
    "path_hint": "export PATH=\"$HOME/.bun/bin:$PATH\"",
    "note": "Pure methodology use (reading SKILL.md only, no scripts) does not need bun."
  },
  "default_entry": "lumilab-home"
}